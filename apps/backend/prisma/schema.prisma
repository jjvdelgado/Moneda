generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  conversions Conversion[]
  alerts Alert[]
}

model Conversion {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  fromCurrency   String
  toCurrency     String
  amount         Float
  result         Float
  rate           Float
  createdAt      DateTime @default(now())
}

model Alert {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id])
  fromCurrency String
  toCurrency   String
  condition    String
  targetRate   Float
  notifyEmail  String?
  triggered    Boolean   @default(false)
  triggeredAt  DateTime?
  createdAt    DateTime  @default(now())
}